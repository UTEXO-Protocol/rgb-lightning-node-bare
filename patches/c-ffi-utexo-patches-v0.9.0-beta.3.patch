+pub(crate) fn sync_wallet(
+    node: &COpaqueStruct,
+    request_json: *const c_char,
+) -> Result<String, Error> {
+    let node = require_handle(node)?;
+    let request: JsonSyncWalletRequest = parse_req(request_json)?;
+    let response = node.sync_wallet(request.mode.into())?;
